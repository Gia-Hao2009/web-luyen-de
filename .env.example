# Copy sang .env khi chay local (netlify dev se tu doc file nay)
# Tren Netlify that: khai bao cac bien nay trong Site settings > Environment variables

AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Bi mat dung de ky token dang nhap (tu nghi 1 chuoi ngau nhien dai, khong chia se)
AUTH_SECRET=change-me-to-a-long-random-string

# Ma PIN noi bo de dang ky tai khoan admin moi o /admin/register.html (chi nguoi biet ma nay moi tao duoc admin)
ADMIN_REGISTER_PIN=1368
